{
  "expo": {
    "name": "BlockZen",
    "slug": "blockzen",
    "version": "1.1.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "blockzen",
    "userInterfaceStyle": "dark",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f2725"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.blockzen.app",
      "requireFullScreen": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      },
      "entitlements": {
        "com.apple.developer.game-center": true
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0f2725"
      },
      "package": "com.blockzen.app",
      "permissions": ["INTERNET"]
    },
    "plugins": [
      "expo-router",
      "expo-asset",
      "expo-font",
      "./plugins/withGameCenter",
      "./plugins/withPlayGames",
      "expo-localization"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "c6e81758-a94d-4c50-91d9-49b22c7d1468"
      },
      "googlePlayGamesAppId": "949312223266"
    }
  }
}
